[
  {
    "name": "l moves right from cursor",
    "text": "abc\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 0 }],
    "keys": ["l"],
    "want": { "text": "abc\n", "mode": "normal", "selections": [{ "anchor": 1, "head": 1 }] }
  },
  {
    "name": "h moves left from cursor",
    "text": "abc\n",
    "mode": "normal",
    "selections": [{ "anchor": 2, "head": 2 }],
    "keys": ["h"],
    "want": { "text": "abc\n", "mode": "normal", "selections": [{ "anchor": 1, "head": 1 }] }
  },
  {
    "name": "j keeps column",
    "text": "abc\ndef\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["j"],
    "want": { "text": "abc\ndef\n", "mode": "normal", "selections": [{ "anchor": 5, "head": 5 }] }
  },
  {
    "name": "h moves left from selection head without skipping selection",
    "text": "hello world\n",
    "mode": "normal",
    "selections": [{ "anchor": 6, "head": 11 }],
    "keys": ["h"],
    "want": { "text": "hello world\n", "mode": "normal", "selections": [{ "anchor": 10, "head": 10 }] }
  },
  {
    "name": "left arrow matches h from selection head",
    "text": "hello world\n",
    "mode": "normal",
    "selections": [{ "anchor": 6, "head": 11 }],
    "keys": ["left"],
    "want": { "text": "hello world\n", "mode": "normal", "selections": [{ "anchor": 10, "head": 10 }] }
  },
  {
    "name": "l moves right from reversed selection head without skipping selection",
    "text": "hello world\n",
    "mode": "normal",
    "selections": [{ "anchor": 11, "head": 6 }],
    "keys": ["l"],
    "want": { "text": "hello world\n", "mode": "normal", "selections": [{ "anchor": 7, "head": 7 }] }
  },
  {
    "name": "right arrow matches l from reversed selection head",
    "text": "hello world\n",
    "mode": "normal",
    "selections": [{ "anchor": 11, "head": 6 }],
    "keys": ["right"],
    "want": { "text": "hello world\n", "mode": "normal", "selections": [{ "anchor": 7, "head": 7 }] }
  },
  {
    "name": "select mode l extends selection",
    "text": "abc\n",
    "mode": "select",
    "selections": [{ "anchor": 0, "head": 0 }],
    "keys": ["l"],
    "want": { "text": "abc\n", "mode": "select", "selections": [{ "anchor": 0, "head": 1 }] }
  },
  {
    "name": "x selects current line including newline",
    "text": "abc\ndef\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["x"],
    "want": { "text": "abc\ndef\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 4 }] }
  },
  {
    "name": "repeated x extends line selection",
    "text": "abc\ndef\nghi\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["x", "x", "x"],
    "want": { "text": "abc\ndef\nghi\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 12 }] }
  },
  {
    "name": "percent selects whole file",
    "text": "abc\ndef\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["%"],
    "want": { "text": "abc\ndef\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 8 }] }
  },
  {
    "name": "gg goes to file start",
    "text": "abc\ndef\n",
    "mode": "normal",
    "selections": [{ "anchor": 5, "head": 5 }],
    "keys": ["g", "g"],
    "want": { "text": "abc\ndef\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 0 }] }
  },
  {
    "name": "select mode gg extends to file start",
    "text": "abc\ndef\n",
    "mode": "select",
    "selections": [{ "anchor": 5, "head": 5 }],
    "keys": ["g", "g"],
    "want": { "text": "abc\ndef\n", "mode": "select", "selections": [{ "anchor": 5, "head": 0 }] }
  },
  {
    "name": "G goes to last line start",
    "text": "abc\ndef",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["G"],
    "want": { "text": "abc\ndef", "mode": "normal", "selections": [{ "anchor": 4, "head": 4 }] }
  },
  {
    "name": "ge goes to end of file",
    "text": "abc\ndef\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["g", "e"],
    "want": { "text": "abc\ndef\n", "mode": "normal", "selections": [{ "anchor": 8, "head": 8 }] }
  },
  {
    "name": "gh goes to line start",
    "text": "abc\ndef\n",
    "mode": "normal",
    "selections": [{ "anchor": 5, "head": 5 }],
    "keys": ["g", "h"],
    "want": { "text": "abc\ndef\n", "mode": "normal", "selections": [{ "anchor": 4, "head": 4 }] }
  },
  {
    "name": "gl goes to line end",
    "text": "abc\ndef\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["g", "l"],
    "want": { "text": "abc\ndef\n", "mode": "normal", "selections": [{ "anchor": 3, "head": 3 }] }
  },
  {
    "name": "gs goes to first non-whitespace",
    "text": "  abc\n",
    "mode": "normal",
    "selections": [{ "anchor": 5, "head": 5 }],
    "keys": ["g", "s"],
    "want": { "text": "  abc\n", "mode": "normal", "selections": [{ "anchor": 2, "head": 2 }] }
  },
  {
    "name": "select mode gl extends to line end",
    "text": "abc\ndef\n",
    "mode": "select",
    "selections": [{ "anchor": 0, "head": 1 }],
    "keys": ["g", "l"],
    "want": { "text": "abc\ndef\n", "mode": "select", "selections": [{ "anchor": 0, "head": 3 }] }
  },
  {
    "name": "f moves to next character on line",
    "text": "abc def\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 0 }],
    "keys": ["f", "d"],
    "want": { "text": "abc def\n", "mode": "normal", "selections": [{ "anchor": 4, "head": 4 }] }
  },
  {
    "name": "t moves till next character on line",
    "text": "abc def\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 0 }],
    "keys": ["t", "d"],
    "want": { "text": "abc def\n", "mode": "normal", "selections": [{ "anchor": 3, "head": 3 }] }
  },
  {
    "name": "F moves to previous character on line",
    "text": "abc def\n",
    "mode": "normal",
    "selections": [{ "anchor": 7, "head": 7 }],
    "keys": ["F", "d"],
    "want": { "text": "abc def\n", "mode": "normal", "selections": [{ "anchor": 4, "head": 4 }] }
  },
  {
    "name": "T moves till previous character on line",
    "text": "abc def\n",
    "mode": "normal",
    "selections": [{ "anchor": 7, "head": 7 }],
    "keys": ["T", "d"],
    "want": { "text": "abc def\n", "mode": "normal", "selections": [{ "anchor": 5, "head": 5 }] }
  },
  {
    "name": "select mode f extends to next character",
    "text": "abc def\n",
    "mode": "select",
    "selections": [{ "anchor": 0, "head": 0 }],
    "keys": ["f", "d"],
    "want": { "text": "abc def\n", "mode": "select", "selections": [{ "anchor": 0, "head": 4 }] }
  },
  {
    "name": "find character does not cross line boundary",
    "text": "abc\ndef\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 0 }],
    "keys": ["f", "d"],
    "want": { "text": "abc\ndef\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 0 }] }
  },
  {
    "name": "multi-selection f preserves primary",
    "text": "abc def\nabc def\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 0 }, { "anchor": 8, "head": 8 }],
    "primary": 1,
    "keys": ["f", "d"],
    "want": { "text": "abc def\nabc def\n", "mode": "normal", "selections": [{ "anchor": 4, "head": 4 }, { "anchor": 12, "head": 12 }], "primary": 1 }
  },
  {
    "name": "multi-selection horizontal motion preserves primary",
    "text": "abc def ghi\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 0 }, { "anchor": 4, "head": 4 }, { "anchor": 8, "head": 8 }],
    "primary": 1,
    "keys": ["l"],
    "want": { "text": "abc def ghi\n", "mode": "normal", "selections": [{ "anchor": 1, "head": 1 }, { "anchor": 5, "head": 5 }, { "anchor": 9, "head": 9 }], "primary": 1 }
  },
  {
    "name": "multi-selection vertical motion preserves primary",
    "text": "abc\ndef\nghi\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }, { "anchor": 5, "head": 5 }],
    "primary": 1,
    "keys": ["j"],
    "want": { "text": "abc\ndef\nghi\n", "mode": "normal", "selections": [{ "anchor": 5, "head": 5 }, { "anchor": 9, "head": 9 }], "primary": 1 }
  },
  {
    "name": "multi-selection goto motion preserves primary",
    "text": "abc\ndef\nghi\n",
    "mode": "normal",
    "selections": [{ "anchor": 2, "head": 2 }, { "anchor": 6, "head": 6 }],
    "primary": 1,
    "keys": ["g", "h"],
    "want": { "text": "abc\ndef\nghi\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 0 }, { "anchor": 4, "head": 4 }], "primary": 1 }
  }
]
