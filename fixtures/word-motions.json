[
  {
    "name": "w selects through trailing separators before next word",
    "text": "hello world\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 0 }],
    "keys": ["w"],
    "want": { "text": "hello world\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 6 }] }
  },
  {
    "name": "repeated w replaces selection from previous head",
    "text": "hello world again\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 0 }],
    "keys": ["w", "w"],
    "want": { "text": "hello world again\n", "mode": "normal", "selections": [{ "anchor": 6, "head": 12 }] }
  },
  {
    "name": "w stops trailing whitespace at newline",
    "text": "hello   \nworld\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 0 }],
    "keys": ["w"],
    "want": { "text": "hello   \nworld\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 8 }] }
  },
  {
    "name": "w at newline moves to first word on next line",
    "text": "hello   \nworld again\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 8 }],
    "keys": ["w"],
    "want": { "text": "hello   \nworld again\n", "mode": "normal", "selections": [{ "anchor": 9, "head": 15 }] }
  },
  {
    "name": "e at newline moves to end of first word on next line",
    "text": "hello\nworld again\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 5 }],
    "keys": ["e"],
    "want": { "text": "hello\nworld again\n", "mode": "normal", "selections": [{ "anchor": 6, "head": 11 }] }
  },
  {
    "name": "b at line start moves to previous line word start",
    "text": "hello world\nagain\n",
    "mode": "normal",
    "selections": [{ "anchor": 12, "head": 17 }],
    "keys": ["b"],
    "want": { "text": "hello world\nagain\n", "mode": "normal", "selections": [{ "anchor": 11, "head": 6 }] }
  },
  {
    "name": "b selects backward to previous word start",
    "text": "hello world\n",
    "mode": "normal",
    "selections": [{ "anchor": 11, "head": 11 }],
    "keys": ["b"],
    "want": { "text": "hello world\n", "mode": "normal", "selections": [{ "anchor": 11, "head": 6 }] }
  },
  {
    "name": "repeated b replaces selection from previous start",
    "text": "hello world again\n",
    "mode": "normal",
    "selections": [{ "anchor": 17, "head": 17 }],
    "keys": ["b", "b"],
    "want": { "text": "hello world again\n", "mode": "normal", "selections": [{ "anchor": 12, "head": 6 }] }
  },
  {
    "name": "b skips punctuation and whitespace to previous word start",
    "text": "hello,   world\n",
    "mode": "normal",
    "selections": [{ "anchor": 13, "head": 13 }],
    "keys": ["b"],
    "want": { "text": "hello,   world\n", "mode": "normal", "selections": [{ "anchor": 13, "head": 9 }] }
  },
  {
    "name": "e selects to current word end",
    "text": "hello world\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["e"],
    "want": { "text": "hello world\n", "mode": "normal", "selections": [{ "anchor": 1, "head": 5 }] }
  },
  {
    "name": "repeated e replaces selection from previous end",
    "text": "hello world again\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["e", "e"],
    "want": { "text": "hello world again\n", "mode": "normal", "selections": [{ "anchor": 5, "head": 11 }] }
  },
  {
    "name": "e skips whitespace to next word end",
    "text": "hello   world\n",
    "mode": "normal",
    "selections": [{ "anchor": 5, "head": 5 }],
    "keys": ["e"],
    "want": { "text": "hello   world\n", "mode": "normal", "selections": [{ "anchor": 5, "head": 13 }] }
  }
]
