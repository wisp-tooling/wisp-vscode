[
  {
    "name": "w selects through trailing separators before next word",
    "text": "hello world\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 0 }],
    "keys": ["w"],
    "want": { "text": "hello world\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 6 }] }
  },
  {
    "name": "repeated w replaces selection from previous head",
    "text": "hello world again\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 0 }],
    "keys": ["w", "w"],
    "want": { "text": "hello world again\n", "mode": "normal", "selections": [{ "anchor": 6, "head": 12 }] }
  },
  {
    "name": "w stops trailing whitespace at newline",
    "text": "hello   \nworld\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 0 }],
    "keys": ["w"],
    "want": { "text": "hello   \nworld\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 8 }] }
  },
  {
    "name": "b selects previous word",
    "text": "hello world\n",
    "mode": "normal",
    "selections": [{ "anchor": 11, "head": 11 }],
    "keys": ["b"],
    "want": { "text": "hello world\n", "mode": "normal", "selections": [{ "anchor": 6, "head": 11 }] }
  },
  {
    "name": "e selects current word",
    "text": "hello world\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["e"],
    "want": { "text": "hello world\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 5 }] }
  }
]
