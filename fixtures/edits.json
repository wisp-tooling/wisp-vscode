[
  {
    "name": "d deletes selected line",
    "text": "abc\ndef\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 4 }],
    "keys": ["d"],
    "want": { "text": "def\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 0 }] }
  },
  {
    "name": "c deletes selection and enters insert",
    "text": "abc\ndef\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 3 }],
    "keys": ["c"],
    "want": { "text": "\ndef\n", "mode": "insert", "selections": [{ "anchor": 0, "head": 0 }] }
  },
  {
    "name": "comma keeps only primary selection",
    "text": "abc def\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }],
    "primary": 1,
    "keys": [","],
    "want": { "text": "abc def\n", "mode": "normal", "selections": [{ "anchor": 4, "head": 7 }] }
  },
  {
    "name": "semicolon keeps only primary selection",
    "text": "abc def\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }],
    "primary": 1,
    "keys": [";"],
    "want": { "text": "abc def\n", "mode": "normal", "selections": [{ "anchor": 4, "head": 7 }] }
  },
  {
    "name": "y yanks selections without changing text",
    "text": "abc def\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }],
    "keys": ["y"],
    "want": { "text": "abc def\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }], "yanked": ["abc", "def"] }
  },
  {
    "name": "I enters insert at line start",
    "text": "  abc\n",
    "mode": "normal",
    "selections": [{ "anchor": 4, "head": 4 }],
    "keys": ["I"],
    "want": { "text": "  abc\n", "mode": "insert", "selections": [{ "anchor": 0, "head": 0 }] }
  },
  {
    "name": "A enters insert at line end",
    "text": "abc\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["A"],
    "want": { "text": "abc\n", "mode": "insert", "selections": [{ "anchor": 3, "head": 3 }] }
  },
  {
    "name": "o opens line below and enters insert",
    "text": "abc\ndef\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["o"],
    "want": { "text": "abc\n\ndef\n", "mode": "insert", "selections": [{ "anchor": 4, "head": 4 }] }
  },
  {
    "name": "O opens line above and enters insert",
    "text": "abc\ndef\n",
    "mode": "normal",
    "selections": [{ "anchor": 5, "head": 5 }],
    "keys": ["O"],
    "want": { "text": "abc\n\ndef\n", "mode": "insert", "selections": [{ "anchor": 4, "head": 4 }] }
  },
  {
    "name": "multi-selection o opens lines below and preserves primary",
    "text": "abc\ndef\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }, { "anchor": 5, "head": 5 }],
    "primary": 1,
    "keys": ["o"],
    "want": { "text": "abc\n\ndef\n\n", "mode": "insert", "selections": [{ "anchor": 4, "head": 4 }, { "anchor": 9, "head": 9 }], "primary": 1 }
  },
  {
    "name": "r replaces selections with repeated character",
    "text": "abc def\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }],
    "keys": ["r", "x"],
    "want": { "text": "xxx xxx\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }] }
  },
  {
    "name": "R replaces selections with yanked text",
    "text": "abc def ghi\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 3 }],
    "keys": ["y", "l", "w", "R"],
    "want": { "text": "abc abcghi\n", "mode": "normal", "selections": [{ "anchor": 4, "head": 7 }], "yanked": ["abc"] }
  },
  {
    "name": "R replaces multiple selections with matching yanked text",
    "text": "abc def ghi jkl\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }],
    "keys": ["y", "l", "w", "R"],
    "want": { "text": "abc abcdefjkl\n", "mode": "normal", "selections": [{ "anchor": 4, "head": 7 }, { "anchor": 8, "head": 11 }], "yanked": ["abc", "def"] }
  },
  {
    "name": "Y joins selections into one yank buffer",
    "text": "abc def\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }],
    "keys": ["Y"],
    "want": { "text": "abc def\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }], "yanked": ["abc\ndef"] }
  },
  {
    "name": "p pastes yanked text after selections",
    "text": "abc def\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }],
    "keys": ["y", "p"],
    "want": { "text": "abcabc defdef\n", "mode": "normal", "selections": [{ "anchor": 3, "head": 6 }, { "anchor": 10, "head": 13 }], "yanked": ["abc", "def"] }
  },
  {
    "name": "p pastes after a cursor outside the cursor position",
    "text": "abc\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["w", "y", "escape", "h", "p"],
    "want": { "text": "abcbc\n", "mode": "normal", "selections": [{ "anchor": 3, "head": 5 }], "yanked": ["bc"] }
  },
  {
    "name": "P pastes at a cursor inside the cursor position",
    "text": "abc\n",
    "mode": "normal",
    "selections": [{ "anchor": 1, "head": 1 }],
    "keys": ["w", "y", "escape", "h", "P"],
    "want": { "text": "abbcc\n", "mode": "normal", "selections": [{ "anchor": 2, "head": 4 }], "yanked": ["bc"] }
  },
  {
    "name": "P pastes yanked text before selections",
    "text": "abc def\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }],
    "keys": ["y", "P"],
    "want": { "text": "abcabc defdef\n", "mode": "normal", "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 7, "head": 10 }], "yanked": ["abc", "def"] }
  },
  {
    "name": "delete yanks deleted selections",
    "text": "abc def\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }],
    "keys": ["d"],
    "want": { "text": " \n", "mode": "normal", "selections": [{ "anchor": 0, "head": 0 }, { "anchor": 1, "head": 1 }], "yanked": ["abc", "def"] }
  },
  {
    "name": "delete preserves primary selection identity",
    "text": "abc def ghi\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }, { "anchor": 8, "head": 11 }],
    "primary": 1,
    "keys": ["d"],
    "want": { "text": "  \n", "mode": "normal", "selections": [{ "anchor": 0, "head": 0 }, { "anchor": 1, "head": 1 }, { "anchor": 2, "head": 2 }], "primary": 1 }
  },
  {
    "name": "change preserves primary selection identity",
    "text": "abc def ghi\n",
    "mode": "normal",
    "selections": [{ "anchor": 0, "head": 3 }, { "anchor": 4, "head": 7 }, { "anchor": 8, "head": 11 }],
    "primary": 2,
    "keys": ["c"],
    "want": { "text": "  \n", "mode": "insert", "selections": [{ "anchor": 0, "head": 0 }, { "anchor": 1, "head": 1 }, { "anchor": 2, "head": 2 }], "primary": 2 }
  }
]
