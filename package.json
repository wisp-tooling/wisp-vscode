{
  "name": "wisp-vscode",
  "version": "0.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "tsc",
    "watch": "tsc -w",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "1.90.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  },
  "main": "./dist/src/vscode/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onCommand:wisp-vscode.key",
    "onCommand:wisp-vscode.enterNormal"
  ],
  "contributes": {
    "commands": [
      {
        "command": "wisp-vscode.key",
        "title": "Wisp: Handle Key"
      },
      {
        "command": "wisp-vscode.enterNormal",
        "title": "Wisp: Enter Normal Mode"
      }
    ],
    "keybindings": [
      {
        "key": ", ",
